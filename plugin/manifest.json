{
  "id": "super-productivity-local-bridge",
  "name": "Local Bridge",
  "description": "Local command bridge for Super Productivity task/project/tag automation",
  "version": "0.1.0",
  "manifestVersion": 1,
  "author": "Cameron Brooks",
  "homepage": "https://github.com/CameronBrooks11/super-productivity-local-bridge",
  "minSupVersion": "14.0.0",
  "permissions": ["nodeExecution"],
  "categories": ["integration", "automation"],
  "tags": ["automation", "tasks", "local-bridge"],
  "iFrame": true,
  "isSkipMenuEntry": true,
  "hooks": ["taskUpdate", "taskComplete", "taskDelete", "currentTaskChange"],
  "changelog": {
    "0.1.0": "Initial scaffold — plugin fallback for Local Bridge"
  }
}
